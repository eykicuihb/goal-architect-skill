{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GoalContract",
  "type": "object",
  "required": [
    "outcome",
    "verification_surface",
    "constraints",
    "boundaries",
    "acceptance_criteria",
    "iteration_policy",
    "blocked_stop_condition",
    "deliverables",
    "risk_level",
    "quality_score"
  ],
  "properties": {
    "outcome": {"type": "string", "minLength": 10},
    "business_value": {"type": "string"},
    "verification_surface": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "boundaries": {
      "type": "object",
      "required": ["in_scope", "out_of_scope"],
      "properties": {
        "in_scope": {"type": "array", "items": {"type": "string"}},
        "out_of_scope": {"type": "array", "items": {"type": "string"}}
      }
    },
    "required_context": {"type": "array", "items": {"type": "string"}},
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "acceptance_criteria": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "iteration_policy": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "checkpoints": {"type": "array", "items": {"type": "string"}},
    "failure_recovery": {"type": "array", "items": {"type": "string"}},
    "blocked_stop_condition": {"type": "string", "minLength": 10},
    "budget_runtime_limit": {"type": "string"},
    "deliverables": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "risk_level": {"type": "string", "enum": ["Low", "Medium", "High"]},
    "estimated_runtime": {"type": "string", "enum": ["Short", "Medium", "Long"]},
    "quality_score": {
      "type": "object",
      "required": ["clarity", "verifiability", "scope_control", "autonomy_readiness", "drift_risk", "overall"],
      "properties": {
        "clarity": {"type": "number", "minimum": 1, "maximum": 10},
        "verifiability": {"type": "number", "minimum": 1, "maximum": 10},
        "scope_control": {"type": "number", "minimum": 1, "maximum": 10},
        "autonomy_readiness": {"type": "number", "minimum": 1, "maximum": 10},
        "drift_risk": {"type": "string", "enum": ["Low", "Medium", "High"]},
        "overall": {"type": "number", "minimum": 1, "maximum": 10}
      }
    }
  }
}
